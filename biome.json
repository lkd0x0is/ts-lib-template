{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": false,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "files": {
    "ignoreUnknown": false,
    "ignore": [
      "packages/*/dist",
      "packages/*/temp",
      "packages/*/*.tsbuildinfo",
      "packages/*/coverage",
      "packages/*/docs-markdown",
      "website/build",
      "website/.docusaurus",
      "website/.vite",
      "website/coverage",
      "website/static",
      "coverage",
      "node_modules/.cache",
      ".github",
      ".gitignore",
      ".nvmrc",
      "pnpm-lock.yaml"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "tab"
  },
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "json": {
    "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 2
    }
  }
}
